pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- starfield demo
-- by dave pitt

function _init()
	-- set screenwidth and height
	screenwidth = 128
	screenheight = 128
	
	-- set number of stars
	numofstars = 400

	-- set maximum speed
	maxspeed = 5

	-- set first colour in 
	-- palette for star colour
	firstcol = 5

	-- num of colours after
	-- first colour to pick
	secondcol = 2

	-- call initstarfield
	initstarfield()
end


function _update()
	-- call updatestars
	updatestars()
end


function _draw()
	-- clear the screen
	cls()

	-- call drawstars
	drawstars()
end

-- initstarfield function
function initstarfield()
	-- create table
	stars={}

	-- run a loop for num of stars
	for i = 1,numofstars do

		-- add item to the table
		-- pulls random numbers
		-- depending on variables
		-- set in _init()
		add(stars,
			{
			x = 1+rnd(screenwidth),
			y = 1+rnd(screenheight),
			speed = 1+rnd(maxspeed),
			col = firstcol+rnd(secondcol)
			}
		)
	end
end

-- draw stars
function drawstars()

	-- run loop for number of stars
	for i = 1, numofstars do

		-- draw a pixel for each star
		pset(stars[i].x,
		stars[i].y,
		stars[i].col)
	end
end

-- update the position of
-- stars depending on button
-- pressed
-- first if detects key press
-- second if wraps star if it
-- goes off the screen
function updatestars()

	for i=1, numofstars do

		-- right
		if btn(➡️) then
			stars[i].x += stars[i].speed
			if stars[i].x > screenwidth then
				stars[i].x = 1
			end
		end

		-- left
		if btn(⬅️) then
			stars[i].x -= stars[i].speed
			if stars[i].x < 1 then
				stars[i].x = screenwidth
			end
		end

		-- up
		if btn(⬆️) then
			stars[i].y -= stars[i].speed
			if stars[i].y < 1 then
			stars[i].y = screenheight
			end
		end

		-- down
		if btn(⬇️) then
			stars[i].y += stars[i].speed
			if stars[i].y > screenheight then
			stars[i].y = 1
			end
		end
	end
end
